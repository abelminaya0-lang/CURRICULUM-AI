service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "abelminaya0@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidCandidate(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.position is string && data.position.size() > 0 && data.position.size() < 100 &&
             data.cvUrl is string && data.cvUrl.size() > 0 &&
             data.status in ["PENDING", "APPROVED", "REJECTED"];
    }

    match /candidates/{candidateId} {
      // Anyone can submit a candidate (create)
      allow create: if isValidCandidate(request.resource.data);
      
      // Only admin can read and update candidates
      allow read, update: if isAdmin();
    }
    
    match /test/{docId} {
      allow read: if true;
    }
  }
}
